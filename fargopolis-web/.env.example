# Base URL of the Java API (no trailing slash). Baked into the client at build time.
VITE_API_URL=http://localhost:8080

# Base URL of the API Gateway HTTP API — Lambda handlers (no trailing slash).
VITE_API_GATEWAY_URL=https://xxxx.execute-api.us-east-2.amazonaws.com

# Clerk publishable key (SPA only). JWT verification uses `clerk.jwtIssuer` on the authorizer Lambda.
VITE_CLERK_PUBLISHABLE_KEY=
